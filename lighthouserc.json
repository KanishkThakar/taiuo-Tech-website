{
  "ci": {
    "collect": {
      "startServerCommand": "pnpm start -p 4173",
      "startServerReadyPattern": "Ready",
      "url": ["http://localhost:4173/"],
      "numberOfRuns": 1,
      "settings": {
        "throttlingMethod": "devtools"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": ["error", { "minScore": 1 }],
        "categories:best-practices": ["error", { "minScore": 1 }],
        "categories:seo": ["error", { "minScore": 1 }],

        "categories:performance": ["warn", { "minScore": 0.9 }],

        "resource-summary:script:size": ["error", { "maxNumericValue": 368640 }],
        "resource-summary:image:size": ["error", { "maxNumericValue": 184320 }],
        "resource-summary:total:size": ["error", { "maxNumericValue": 665600 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.02 }]
      }
    },
    "upload": { "target": "temporary-public-storage" }
  }
}
